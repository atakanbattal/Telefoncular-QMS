# Netlify: hash'li asset'ler uzun önbellek; shell asla — eski HTML yeni chunk'a işaret edince boş sayfa olur.
/assets/*
  Cache-Control: public, max-age=31536000, immutable

/index.html
  Cache-Control: no-cache, no-store, must-revalidate, max-age=0
  Pragma: no-cache

/
  Cache-Control: no-cache, no-store, must-revalidate, max-age=0

# Gerçek çok boyutlu ICO (Pillow ICO); image/png değil
/favicon.ico
  Content-Type: image/x-icon
  X-Content-Type-Options: nosniff

/favicon.png
  Content-Type: image/png
  X-Content-Type-Options: nosniff

/favicon-16.png
  Content-Type: image/png
  X-Content-Type-Options: nosniff

/favicon-32.png
  Content-Type: image/png
  X-Content-Type-Options: nosniff

/apple-touch-icon.png
  Content-Type: image/png
  X-Content-Type-Options: nosniff
