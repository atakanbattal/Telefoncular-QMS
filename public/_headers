# Netlify: hash'li asset'ler uzun önbellek; shell asla — eski HTML yeni chunk'a işaret edince boş sayfa olur.
/assets/*
  Cache-Control: public, max-age=31536000, immutable

/index.html
  Cache-Control: no-cache, no-store, must-revalidate, max-age=0
  Pragma: no-cache

/
  Cache-Control: no-cache, no-store, must-revalidate, max-age=0

# .ico uzantısı ama içerik PNG — doğru MIME (aksi halde sekme ikonu bozulur)
/favicon.ico
  Content-Type: image/png
  X-Content-Type-Options: nosniff

/favicon.png
  Content-Type: image/png
  X-Content-Type-Options: nosniff

/favicon-16.png
  Content-Type: image/png
  X-Content-Type-Options: nosniff

/apple-touch-icon.png
  Content-Type: image/png
  X-Content-Type-Options: nosniff
